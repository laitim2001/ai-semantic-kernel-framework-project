{
  "name": "ipa-platform-v2-frontend",
  "version": "2.0.0-alpha",
  "private": true,
  "type": "module",
  "description": "IPA Platform V2 frontend (React 18 + Vite 5 + Zustand)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "check:mockup-fidelity": "node scripts/check-mockup-fidelity.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "i18n:extract": "i18next-parser --config i18next-parser.config.cjs",
    "lhci": "lhci autorun",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:visual:update": "RUN_VISUAL=1 playwright test visual --update-snapshots"
  },
  "dependencies": {
    "@fontsource/geist-mono": "5.1.0",
    "@fontsource/geist-sans": "5.1.0",
    "@fontsource/noto-sans-tc": "5.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^10.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^6.27.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "web-vitals": "^5.2.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "i18next-parser": "^9.4.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
