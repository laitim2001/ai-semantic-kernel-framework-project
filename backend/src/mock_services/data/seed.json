  "kb_articles": [
    {"id": "kb_001", "title": "How to reset 2FA", "content": "Navigate to Settings > Security > Two-Factor Authentication and click Reset. You will need your recovery code or contact admin.", "tags": ["security", "auth", "2fa"]},
    {"id": "kb_002", "title": "API rate limit policy", "content": "Free tier 60 req/min. Pro tier 600 req/min. Enterprise tier custom. Throttling returns HTTP 429 with Retry-After header.", "tags": ["api", "limits"]},
    {"id": "kb_003", "title": "SSO configuration for enterprise", "content": "Enterprise customers can configure SAML 2.0 or OIDC. SCIM provisioning supported. Contact onboarding team for setup wizard.", "tags": ["sso", "enterprise", "auth"]},
    {"id": "kb_004", "title": "Server health check best practices", "content": "Run patrol at 5-minute intervals during business hours. Track CPU/memory/disk + custom service heartbeats. Alert on health=critical only.", "tags": ["patrol", "monitoring", "ops"]},
    {"id": "kb_005", "title": "Incident severity classification", "content": "Critical: customer-facing outage. High: degraded service. Medium: internal impact only. Low: cosmetic / docs issue.", "tags": ["incident", "severity", "ops"]},
    {"id": "kb_006", "title": "Webhook retry strategy", "content": "Webhooks retry 5 times with exponential backoff (2s, 4s, 8s, 16s, 32s). After all retries, marked as failed in dashboard.", "tags": ["webhook", "integration"]},
    {"id": "kb_007", "title": "Audit log retention", "content": "All audit events retained 365 days for pro/enterprise. 90 days for free tier. Export via /api/v1/audit/export endpoint.", "tags": ["audit", "compliance", "retention"]},
    {"id": "kb_008", "title": "Root cause analysis workflow", "content": "Step 1: collect alerts. Step 2: correlate by time/server. Step 3: form hypothesis. Step 4: gather evidence. Step 5: confirm fix.", "tags": ["rca", "ops", "workflow"]}
