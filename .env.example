# IPA Platform V2 — Environment variables example
#
# Copy this file to .env and fill in actual secrets.
# .env is gitignored; never commit it.
#
# Authority: docs/03-implementation/agent-harness-planning/
# Compliance: 10-server-side-philosophy.md (LLM provider neutrality)

# ----------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
APP_VERSION=2.0.0-alpha

# ----------------------------------------------------------------------
# PostgreSQL (matches docker-compose.dev.yml)
# ----------------------------------------------------------------------
DB_NAME=ipa_v2
DB_USER=ipa_v2
DB_PASSWORD=ipa_v2_dev
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://ipa_v2:ipa_v2_dev@localhost:5432/ipa_v2

# Async pool tuning (Sprint 49.2)
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SEC=300
DB_ECHO=false

# ----------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------
# RabbitMQ
# ----------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ----------------------------------------------------------------------
# Qdrant (vector DB)
# ----------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# ----------------------------------------------------------------------
# LLM Providers — V2 PRIMARY: Azure OpenAI
#
# Note: per V2 LLM-provider-neutrality (10-server-side-philosophy.md),
# agent_harness/** never imports these directly. They are consumed only
# by adapters/azure_openai/.
# ----------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ----------------------------------------------------------------------
# LLM Providers — Optional adapters (Phase 50+ if approved)
#
# Leave commented unless the corresponding adapter is enabled in
# providers.yaml.
# ----------------------------------------------------------------------
# ANTHROPIC_API_KEY=<your-anthropic-key>
# OPENAI_API_KEY=<your-openai-key>

# ----------------------------------------------------------------------
# Identity / Multi-tenancy (filled in during Sprint 49.2-49.3)
# ----------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ----------------------------------------------------------------------
# WorkOS OIDC (Sprint 57.7 US-A2 — IAM Hosted vendor)
#
# DEV NOTE: you do NOT need a WorkOS account for local development. Leave
# WORKOS_API_KEY blank — the OIDC routes (/api/v1/auth/login + /callback)
# return 503, and you authenticate via POST /api/v1/auth/dev-login instead
# (the login page shows a "Dev login" form when import.meta.env.DEV is true).
# Fill these only for staging/prod where real SSO is required.
# ----------------------------------------------------------------------
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Backend callback URL registered with WorkOS (client secret lives server-side).
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
# Public SPA origin the backend redirects the browser back to after callback.
FRONTEND_BASE_URL=http://localhost:3007
# httpOnly auth-cookie Secure flag — false in dev (http localhost), MUST be
# true in prod (https).
COOKIE_SECURE=false

# Azure AD (V1 carryover — superseded by WorkOS OIDC above; kept for reference)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=

# ----------------------------------------------------------------------
# Observability (Sprint 49.4 wiring)
# ----------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ipa-v2-backend

# Sentry (frontend error reporting) — leave blank in dev. The Vite app reads
# import.meta.env.VITE_SENTRY_DSN; when blank, Sentry init is skipped.
VITE_SENTRY_DSN=
